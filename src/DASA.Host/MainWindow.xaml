<Window x:Class="DASA.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="D.A.S.A"
        Height="780"
        Width="1180"
        MinHeight="560"
        MinWidth="880"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0A0A0A">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      CornerRadius="8"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Grid>
        <wv2:WebView2 x:Name="WebView" />
        <Border x:Name="LoadingOverlay"
                Background="#0A0A0A"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#D71921" Margin="0,0,10,0" />
                    <TextBlock Text="D.A.S.A"
                               FontFamily="Segoe UI"
                               FontSize="28"
                               FontWeight="Light"
                               Foreground="#FFFFFF"
                               HorizontalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="DOWNLOAD AUTOMATION &amp; SECURITY"
                           Margin="0,10,0,0"
                           FontSize="11"
                           Foreground="#666666"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="LoadingStatus"
                           Margin="0,28,0,0"
                           Text="Starting WebView2…"
                           FontSize="12"
                           Foreground="#444444"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
